<% layout("/layouts/boilerplate") %>
<div class="row">
  <div class="col-8 offset-2">
    <br><br>
    <h3>Create a New Listing</h3>
    <form method="POST" action="/listings">
      <div class="mb-3">
        <label for="title" class="form-label mb-0">Title</label>
        <input
          type="text"
          name="listing[title]"
          placeholder="Add a catchy title"
          class="form-control"
        />
      </div>
      <div class="mb-3">
        <label for="Description" class="form-label mb-0">Description</label>
        <textarea
          type="text"
          rows="2"
          name="listing[description]"
          class="form-control"
        ></textarea>
      </div>
      <div class="mb-3">
        <label for="image" class="form-label mb-0">Image Link</label>
        <input
          type="text"
          name="listing[image]"
          placeholder="Enter image URL/link"
          class="form-control"
        />
      </div>
      <div class="row">
        <div class="mb-3 col-md-4">
          <label for="price" class="form-label mb-0">Price</label>
          <input
            type="number"
            name="listing[price]"
            placeholder="1200"
            class="form-control"
          />
        </div>
        <div class="mb-3 col-md-8">
          <label for="country" class="form-label mb-0">Country</label>
          <input
            type="text"
            name="listing[country]"
            placeholder="Nepal"
            class="form-control"
          />
        </div>
      </div>
      <div class="mb-3">
        <label for="location" class="form-label mb-0">Location</label>
        <input
          type="text"
          name="listing[location]"
          placeholder="Kathmandu"
          class="form-control"
        />
      </div>
      <button class="btn btn-dark mb-3 add-btn">Add</button>
    </form>
  </div>
</div>
